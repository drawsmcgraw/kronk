# SearXNG configuration — TEMPLATE
#
# Copy this file to settings.yml and give it a unique secret_key:
#   cp searxng/settings.yml.example searxng/settings.yml
#   sed -i "s/ultrasecretkey/$(openssl rand -hex 32)/" searxng/settings.yml
#
# searxng/settings.yml is gitignored, so your real secret_key never gets
# committed. SearXNG refuses to start while secret_key is "ultrasecretkey".

use_default_settings: true

general:
  debug: false
  instance_name: "Kronk Search"

search:
  safe_search: 0
  default_lang: "en"
  formats:
    - html
    - json

server:
  # Replace with a unique random value — see the header of this file.
  secret_key: "ultrasecretkey"
  bind_address: "127.0.0.1"
  port: 8080
  public_instance: false

engines:
  - name: google
    engine: google
    categories: general
    disabled: false

  - name: bing
    engine: bing
    categories: general
    disabled: false

  - name: wikipedia
    engine: wikipedia
    categories: general
    disabled: false

  - name: duckduckgo
    engine: duckduckgo
    categories: general
    disabled: false

# Disable everything else
  - name: google images
    engine: google_images
    disabled: true

  - name: google news
    engine: google_news
    disabled: true

  - name: bing images
    engine: bing_images
    disabled: true

  - name: bing news
    engine: bing_news
    disabled: true

  - name: reddit
    engine: reddit
    disabled: true

  - name: twitter
    engine: twitter
    disabled: true

categories_as_tabs:
  general: {}
